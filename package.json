{
  "name": "knowmesh",
  "version": "0.1.0",
  "private": false,
  "description": "Local-first knowledge asset compiler for auditable RAG, traceable citations, and maintainable document intelligence.",
  "keywords": [
    "knowledge-base",
    "knowledge-asset",
    "rag",
    "retrieval-augmented-generation",
    "local-first",
    "document-ai",
    "document-intelligence",
    "document-processing",
    "sqlite",
    "sqlite-first",
    "vector-search",
    "citations",
    "auditable-ai",
    "knowledge-graph",
    "k12",
    "textbook",
    "aliyun",
    "dashscope",
    "education"
  ],
  "homepage": "https://github.com/shineway-tech/KnowMesh#readme",
  "bugs": {
    "url": "https://github.com/shineway-tech/KnowMesh/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shineway-tech/KnowMesh.git"
  },
  "author": "Shineway Tech",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": "./src/sdk/knowmesh-client.mjs",
    "./sdk": "./src/sdk/knowmesh-client.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "knowmesh": "./src/cli/knowmesh.mjs"
  },
  "scripts": {
    "start": "node ./src/cli/knowmesh.mjs start",
    "smoke:release": "node ./scripts/release-smoke.mjs",
    "smoke:browser-sample": "node ./scripts/browser-sample-smoke.mjs",
    "smoke:artifact": "node ./scripts/verify-release-artifact.mjs",
    "smoke:sdk-consumer": "node ./scripts/sdk-consumer-smoke.mjs",
    "smoke:live-sdk": "node ./scripts/live-sdk-sample-smoke.mjs",
    "smoke:operator-workflow": "node ./scripts/operator-workflow-smoke.mjs",
    "smoke:first-run-usability": "node ./scripts/first-run-usability-smoke.mjs",
    "smoke:usable-product": "node ./scripts/usable-product-smoke.mjs",
    "smoke:release-candidate": "node ./scripts/release-candidate-evidence.mjs",
    "smoke:public-launch": "node ./scripts/public-launch-evidence.mjs",
    "smoke:stabilization": "node ./scripts/stabilization-evidence.mjs",
    "smoke:api-reliability": "node ./scripts/api-reliability-evidence.mjs",
    "smoke:community-release": "node ./scripts/community-release-readiness-evidence.mjs",
    "smoke:final-publication": "node ./scripts/final-publication-review-evidence.mjs",
    "verify:package-boundary": "node ./scripts/verify-package-boundary.mjs",
    "verify:integration-privacy": "node ./scripts/verify-integration-privacy.mjs",
    "verify:release-gate": "node ./scripts/release-gate.mjs",
    "generate:release-evidence": "node ./scripts/generate-release-evidence.mjs",
    "generate:release-candidate": "node ./scripts/release-candidate-evidence.mjs --out",
    "generate:public-launch": "node ./scripts/public-launch-evidence.mjs --out",
    "generate:stabilization": "node ./scripts/stabilization-evidence.mjs --out",
    "generate:api-reliability": "node ./scripts/api-reliability-evidence.mjs --out",
    "generate:community-release": "node ./scripts/community-release-readiness-evidence.mjs --out",
    "generate:final-publication": "node ./scripts/final-publication-review-evidence.mjs --out",
    "doctor": "node ./src/cli/knowmesh.mjs doctor --config examples/local-demo/kb.yaml",
    "doctor:textbook": "node ./src/cli/knowmesh.mjs doctor --config examples/textbook-cn-k12/kb.yaml --cloud",
    "config": "node ./src/cli/knowmesh.mjs config",
    "scan": "node ./src/cli/knowmesh.mjs scan",
    "plan": "node ./src/cli/knowmesh.mjs plan",
    "demo:plan": "node ./src/cli/knowmesh.mjs plan --config examples/local-demo/kb.yaml --write",
    "test": "node --test"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "yaml": "^2.7.0"
  }
}
