KNOWMESH_ENV=local
KNOWMESH_WORKSPACE=./workspace
KNOWMESH_K12_SOURCE_ROOT=

ALIYUN_REGION=cn-hangzhou
ALIYUN_OSS_BUCKET=knowmesh-example-oss
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_PROFILE=default
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=

ALIYUN_VECTOR_BUCKET=knowmesh-example-vector
ALIYUN_VECTOR_INDEX=knowmesh_example_v1
ALIYUN_VECTOR_ACCOUNT_ID=

QWEN_API_KEY=
DASHSCOPE_API_KEY=
ALIYUN_BAILIAN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

KNOWMESH_OCR_MODEL=qwen-vl-ocr-2025-11-20
KNOWMESH_EMBEDDING_MODEL=text-embedding-v4
